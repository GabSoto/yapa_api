# --- Django ---
SECRET_KEY= cambia-esto-por-una-clave-segura
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Base de datos ---
# Local (por defecto): SQLite. No hace falta configurar nada.
# Despliegue: descomentar y completar con los datos de Supabase/PostgreSQL.
# DB_ENGINE=postgresql
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=tu_password
# DB_HOST=db.xxxx.supabase.co
# DB_PORT=5432

# --- CORS (orígenes permitidos, separados por coma) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Supabase Storage (imágenes de productos) ---
# Si no se configura, las imágenes se guardan en MEDIA local (desarrollo).
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_KEY=tu_service_role_key
# SUPABASE_BUCKET=productos
